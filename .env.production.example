# ===== Database =====
POSTGRES_DB=cozyletters
POSTGRES_USER=cozyletters
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ===== Backend =====
DATABASE_URL=jdbc:postgresql://postgres:5432/cozyletters
DATABASE_USER=cozyletters
DATABASE_PASSWORD=CHANGE_ME_strong_password_here

# ===== JWT =====
# Must be at least 32 characters (256 bits) for HS256
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32
JWT_EXPIRATION=86400000

# ===== OAuth2 (Google) =====
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===== URLs =====
# Set these to your production domain
CORS_ALLOWED_ORIGINS=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=https://yourdomain.com/api
